<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zetu Cart - Your Premier Shopping Destination</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .hero-pattern {
            background-color: #ffffff;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23f9a826' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        .gradient-text {
            background: linear-gradient(45deg, #ff6600, #ff5100dc);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .nav-links {
    display: none;
}

@media (min-width: 768px) {
    .nav-links {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
}

.mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: white;
    z-index: 50;
    transform: translateX(-100%);
    transition: transform 300ms ease-in-out;
    overflow-y: auto;
}

.mobile-menu.active {
    transform: translateX(0);
}

.mobile-menu-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100%;
    gap: 1.5rem;
    text-align: center;
    padding: 2rem;
}

.mobile-menu-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 1.5rem;
    cursor: pointer;
    z-index: 60;
}

.hamburger-icon {
    display: block;
    color: #1f2937;
    padding: 0.5rem;
    outline: none;
    z-index: 60;
}

@media (min-width: 768px) {
    .hamburger-icon {
        display: none;
    }
}

.mobile-menu-container a {
    width: 100%;
    padding: 1rem 0;
    font-size: 1.5rem;
    transition: background-color 300ms;
}

.mobile-menu-container a:hover {
    background-color: #fff7ed;
}
    </style>
</head>
<body class="font-sans">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg fixed w-full z-50">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center">
                    <a href="/products/all" class="flex items-center">
                        <span class="text-2xl font-bold gradient-text">ZetuCart</span>
                    </a>
                </div>
        
                <!-- Desktop Navigation -->
                <div class="nav-links">
                    <a href="/products/all" class="text-gray-800 hover:text-orange-500 px-3 py-2">Home</a>
                    <a href="#categories" class="text-gray-800 hover:text-orange-500 px-3 py-2">Categories</a>
                    <a href="#features" class="text-gray-800 hover:text-orange-500 px-3 py-2">Features</a>
                    <a href="#deals" class="text-gray-800 hover:text-orange-500 px-3 py-2">Deals</a>
                    <% if (isAuthenticated) { %>
                        <a href="/profile/user-profile" class="text-gray-800 hover:text-orange-500 px-3 py-2">Profile</a>
                        <a href="/auth/logout" class="text-gray-800 hover:text-orange-500 px-3 py-2">Logout</a>
                    <% } else { %>
                        <a href="/login" class="text-gray-800 hover:text-orange-500 px-3 py-2">Login</a>
                        <a href="/signup" class="inline-block bg-gradient-to-r from-yellow-400 to-orange-500 text-white px-6 py-3 rounded-full font-medium text-center shadow-md hover:from-yellow-500 hover:to-orange-600 focus:ring-2 focus:ring-yellow-300 focus:outline-none transition duration-300 ease-in-out">
                            Sign Up
                        </a>
                    <% } %>
                </div>
        
                <!-- Hamburger Icon -->
                <button id="hamburger-icon" class="hamburger-icon">
                    <i class="fas fa-bars text-2xl"></i>
                </button>
            </div>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="mobile-menu">
        <div class="mobile-menu-close" id="mobile-menu-close">
            <i class="fas fa-times"></i>
        </div>
        <div class="mobile-menu-container">
            <a href="/products/all" class="text-2xl text-gray-800 hover:text-orange-500">Home</a>
            <a href="#categories" class="text-2xl text-gray-800 hover:text-orange-500">Categories</a>
            <a href="#features" class="text-2xl text-gray-800 hover:text-orange-500">Features</a>
            <a href="#deals" class="text-2xl text-gray-800 hover:text-orange-500">Deals</a>
            <% if (isAuthenticated) { %>
                <a href="/profile/user-profile" class="text-2xl text-gray-800 hover:text-orange-500">Profile</a>
                <a href="/auth/logout" class="text-2xl text-gray-800 hover:text-orange-500">Logout</a>
            <% } else { %>
                <a href="/login" class="text-2xl text-gray-800 hover:text-orange-500">Login</a>
                <a href="/signup" class="text-2xl bg-gradient-to-r from-yellow-400 to-orange-500 text-white px-8 py-4 rounded-full">
                    Sign Up
                </a>
            <% } %>
        </div>
    </div>
    <!-- Hero section -->
    <section class="hero-pattern pt-24 pb-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row items-center justify-between">
                <div class="md:w-1/2 mb-8 md:mb-0">
                    <h1 class="text-4xl md:text-6xl font-bold mb-6">
                        Shop Smart, <span class="gradient-text">Shop Zetu</span>
                    </h1>
                    <p class="text-gray-600 text-lg mb-8">
                        Discover Kenya's premier online shopping destination. Quality products, amazing deals, and fast delivery across the country.
                    </p>
                    <div class="flex space-x-4">
                        <button class="bg-orange-500 text-white px-8 py-3 rounded-full hover:bg-orange-600 transition">
                            Learn More
                        </button>
                        <a href="/products/all" class="border-2 border-orange-500 text-orange-500 px-8 py-3 rounded-full hover:bg-orange-50 transition inline-block text-center">
                            Start Shopping
                        </a>
                    </div>
                </div>
                <div class="md:w-1/2 hidden sm:block"> <!-- Hide image on small screens -->
                    <img src="./images/zetu1.jpg" alt="Shopping Experience" class="rounded-lg shadow-xl">
                </div>
            </div>
        </div>
    </section>
    

    <!-- Features Section -->
    <section id="features" class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4">
            <h2 class="text-3xl font-bold text-center mb-12">Why Choose Zetu Cart?</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="p-6 text-center">
                    <div class="w-16 h-16 mx-auto mb-4 bg-orange-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-truck text-2xl text-orange-500"></i>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">Fast Delivery</h3>
                    <p class="text-gray-600">Next-day delivery available in major cities across Kenya</p>
                </div>
                <div class="p-6 text-center">
                    <div class="w-16 h-16 mx-auto mb-4 bg-orange-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-shield-alt text-2xl text-orange-500"></i>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">Secure Payments</h3>
                    <p class="text-gray-600">Multiple payment options including M-Pesa integration</p>
                </div>
                <div class="p-6 text-center">
                    <div class="w-16 h-16 mx-auto mb-4 bg-orange-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-undo text-2xl text-orange-500"></i>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">Easy Returns</h3>
                    <p class="text-gray-600">Hassle-free returns within 7 days of purchase</p>
                </div>
            </div>
        </div>
    </section>

    <!-- invite section-->

    <!-- Join Options Section -->
<section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-4xl font-bold text-center text-gray-800 mb-6">Join Our Community</h2>
        <p class="text-lg text-gray-600 text-center mb-12">Choose your journey with ZetuCart - whether you're here to shop or sell, we've got you covered</p>
        
        <div class="grid md:grid-cols-2 gap-8">
            <!-- Buyer Card -->
            <div class="group relative bg-gradient-to-br from-yellow-50 to-yellow-100 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="absolute top-6 right-6 w-16 h-16 bg-orange-500/10 rounded-full flex items-center justify-center">
                    <i class="fas fa-shopping-cart text-2xl text-orange-500"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-800 mb-4">Join as a Buyer</h3>
                <ul class="space-y-3 mb-8">
                    <li class="flex items-center text-gray-600">
                        <i class="fas fa-chevron-right text-orange-500 mr-2"></i>
                        Access thousands of quality products
                    </li>
                    <li class="flex items-center text-gray-600">
                        <i class="fas fa-chevron-right text-orange-500 mr-2"></i>
                        Enjoy secure payments & fast delivery
                    </li>
                    <li class="flex items-center text-gray-600">
                        <i class="fas fa-chevron-right text-orange-500 mr-2"></i>
                        Get exclusive deals & discounts
                    </li>
                    <li class="flex items-center text-gray-600">
                        <i class="fas fa-chevron-right text-orange-500 mr-2"></i>
                        Easy returns & 24/7 support
                    </li>
                </ul>
                <% if (isAuthenticated) { %>
                    <a href="/shop" class="w-full bg-orange-500 text-white py-3 px-6 rounded-full font-semibold hover:bg-orange-600 transition-colors duration-300 flex items-center justify-center group-hover:scale-105 transform">
                        Start Shopping
                        <i class="fas fa-chevron-right ml-2"></i>
                    </a>
                <% } else { %>
                    <a href="/signup?type=buyer" class="w-full bg-yellow-500 text-white py-3 px-6 rounded-full font-semibold hover:bg-orange-600 transition-colors duration-300 flex items-center justify-center group-hover:scale-105 transform">
                        Join as Buyer
                        <i class="fas fa-chevron-right ml-2"></i>
                    </a>
                <% } %>
            </div>

            <!-- Seller Card -->
            <div class="group relative bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="absolute top-6 right-6 w-16 h-16 bg-blue-500/10 rounded-full flex items-center justify-center">
                    <i class="fas fa-store text-2xl text-blue-500"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-800 mb-4">Join as a Seller</h3>
                <ul class="space-y-3 mb-8">
                    <li class="flex items-center text-gray-600">
                        <i class="fas fa-chevron-right text-blue-500 mr-2"></i>
                        Reach millions of potential customers
                    </li>
                    <li class="flex items-center text-gray-600">
                        <i class="fas fa-chevron-right text-blue-500 mr-2"></i>
                        Easy-to-use seller dashboard
                    </li>
                    <li class="flex items-center text-gray-600">
                        <i class="fas fa-chevron-right text-blue-500 mr-2"></i>
                        Secure & timely payments
                    </li>
                    <li class="flex items-center text-gray-600">
                        <i class="fas fa-chevron-right text-blue-500 mr-2"></i>
                        Professional growth & training
                    </li>
                </ul>
                <% if (isAuthenticated) { %>
                    <a href="/seller/dashboard" class="w-full bg-blue-500 text-white py-3 px-6 rounded-full font-semibold hover:bg-blue-600 transition-colors duration-300 flex items-center justify-center group-hover:scale-105 transform">
                        Go to Seller Dashboard
                        <i class="fas fa-chevron-right ml-2"></i>
                    </a>
                <% } else { %>
                    <a href="/seller/register" class="w-full bg-blue-500 text-white py-3 px-6 rounded-full font-semibold hover:bg-blue-600 transition-colors duration-300 flex items-center justify-center group-hover:scale-105 transform">
                        Join as Seller
                        <i class="fas fa-chevron-right ml-2"></i>
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</section>

    <!-- Categories Section -->
    <!-- Categories Section -->
<section id="categories" class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-12">Popular Categories</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <% const categories = [
                { name: 'Fashion and Textile', image: './images/prod22.png' },
                { name: 'Home & Living', image: './images/home.jpeg' },
                { name: 'Beauty', image: './images/beauty.jpeg' },
                { name: 'Art and collectibles', image: './images/paintings.jpg'}
            ]; %>
            <% categories.forEach(category => { %>
                <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition">
                    <img src="<%= category.image %>" alt="<%= category.name %>" class="w-full h-48 object-cover">
                    <div class="p-4">
                        <h3 class="text-lg font-semibold mb-2"><%= category.name %></h3>
                        <a href="/products/all" class="text-orange-500 hover:text-orange-600">Shop Now →</a>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</section>


<!-- Deals Section -->
<section id="deals" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
        <!-- Section Header -->
        <div class="flex items-center justify-between mb-10">
            <div>
                <h2 class="text-3xl font-extrabold text-gray-900">Hot Deals</h2>
                <p class="text-gray-500 mt-1">Limited time offers — don't miss out</p>
            </div>
            <a href="/products/all" class="text-orange-500 hover:text-orange-600 font-semibold text-sm flex items-center gap-1">
                View All <i class="fas fa-chevron-right text-xs"></i>
            </a>
        </div>

        <!-- Deals Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <!-- Deal 1: Flash Sale -->
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 group">
                <div class="relative bg-orange-50 h-48 flex items-center justify-center">
                    <span class="absolute top-3 left-3 bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Flash Sale</span>
                    <img src="./images/sandals.jpeg" alt="Flash Sale" class="h-36 w-full object-cover">
                </div>
                <div class="p-5">
                    <p class="text-gray-500 text-xs mb-1 uppercase tracking-wide">Fashion & Footwear</p>
                    <h3 class="text-gray-900 font-semibold text-base mb-3 leading-snug">Selected items up to 50% off</h3>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="text-orange-500 font-bold text-xl">From KSh 499</span>
                        <span class="text-gray-400 line-through text-sm">KSh 999</span>
                        <span class="bg-red-100 text-red-600 text-xs font-semibold px-2 py-0.5 rounded">-50%</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-1 text-orange-500 text-xs font-medium">
                            <i class="fas fa-clock"></i>
                            <span>Ends in 24 hrs</span>
                        </div>
                        <a href="/products/all" class="bg-orange-500 text-white text-sm px-5 py-2 rounded-full hover:bg-orange-600 transition font-semibold">
                            Shop Now
                        </a>
                    </div>
                </div>
            </div>

            <!-- Deal 2: Clearance -->
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 group">
                <div class="relative bg-blue-50 h-48 flex items-center justify-center">
                    <span class="absolute top-3 left-3 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Clearance</span>
                    <img src="./images/electronics.jpeg" alt="Clearance" class="h-36 w-full object-cover">
                </div>
                <div class="p-5">
                    <p class="text-gray-500 text-xs mb-1 uppercase tracking-wide">Electronics</p>
                    <h3 class="text-gray-900 font-semibold text-base mb-3 leading-snug">Clearance on electronics &amp; accessories</h3>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="text-orange-500 font-bold text-xl">From KSh 1,400</span>
                        <span class="text-gray-400 line-through text-sm">KSh 2,000</span>
                        <span class="bg-blue-100 text-blue-600 text-xs font-semibold px-2 py-0.5 rounded">-30%</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-1 text-blue-500 text-xs font-medium">
                            <i class="fas fa-clock"></i>
                            <span>3 Days Left</span>
                        </div>
                        <a href="/products/all" class="bg-orange-500 text-white text-sm px-5 py-2 rounded-full hover:bg-orange-600 transition font-semibold">
                            Explore
                        </a>
                    </div>
                </div>
            </div>

            <!-- Deal 3: Bundle Deal -->
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 group">
                <div class="relative bg-purple-50 h-48 flex items-center justify-center">
                    <span class="absolute top-3 left-3 bg-purple-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Bundle Deal</span>
                    <img src="./images/beauty.jpeg" alt="Bundle Deal" class="h-36 w-full object-cover">
                </div>
                <div class="p-5">
                    <p class="text-gray-500 text-xs mb-1 uppercase tracking-wide">Beauty &amp; Personal Care</p>
                    <h3 class="text-gray-900 font-semibold text-base mb-3 leading-snug">Buy 2 Get 1 Free on beauty products</h3>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="text-orange-500 font-bold text-xl">Buy 2 Get 1</span>
                        <span class="bg-purple-100 text-purple-600 text-xs font-semibold px-2 py-0.5 rounded">Limited</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-1 text-purple-500 text-xs font-medium">
                            <i class="fas fa-tag"></i>
                            <span>While stocks last</span>
                        </div>
                        <a href="/products/all" class="bg-orange-500 text-white text-sm px-5 py-2 rounded-full hover:bg-orange-600 transition font-semibold">
                            Get Deal
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

    

   
         <!-- Partners Section -->
